---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { Trophy, Calendar, ExternalLink, Activity } from 'lucide-vue-next';

const eventEntries = await getCollection('events');
const events = eventEntries.map(entry => entry.data);

const upcomingEvents = events.filter((e) => e.status === 'upcoming');
const completedEvents = events.filter((e) => e.status === 'completed');
---

<Layout title="Events">
	<div class="max-w-7xl mx-auto px-4 py-12 md:py-20">
		<header class="mb-12 md:mb-20 px-2">
			<h1 class="text-3xl md:text-4xl font-black tracking-tighter mb-4">Operations Timeline</h1>
			<p class="text-zinc-500 text-sm md:text-base">Our past victories and upcoming deployments.</p>
		</header>

		<div class="grid grid-cols-1 lg:grid-cols-3 gap-16 lg:gap-12">
			<!-- Main Timeline -->
			<div class="lg:col-span-2 space-y-12">
				<h2 class="text-2xl font-black tracking-tighter flex items-center gap-3 px-2">
					<Trophy class="w-6 h-6 text-accent-purple" />
					Mission History
				</h2>
				
				<div class="space-y-8 md:space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-accent-purple before:via-stealth before:to-transparent">
					{completedEvents.map((event) => (
						<div class="relative flex items-start justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
							<div class="flex items-center justify-center w-10 h-10 rounded-full border border-stealth bg-graphite group-[.is-active]:border-accent-purple text-zinc-500 group-[.is-active]:text-accent-purple shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 transition-all mt-1 md:mt-0">
								<Activity class="w-4 h-4" />
							</div>
							<div class="w-[calc(100%-3.5rem)] md:w-[calc(50%-2.5rem)] px-2 md:px-4">
								<Card class="hover:border-accent-purple/50 transition-colors p-4 md:p-5">
									<div class="flex flex-col sm:flex-row justify-between items-start gap-2 mb-3 md:mb-2">
										<h3 class="font-bold text-white text-base md:text-lg">{event.name}</h3>
										<span class="text-accent-cyan font-mono font-bold text-xs md:text-sm">{event.placement}</span>
									</div>
									<div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-[10px] text-zinc-500 font-mono uppercase tracking-widest">
										<div class="flex items-center gap-1">
											<Calendar class="w-3 h-3" />
											{event.date}
										</div>
										{event.score && <div class="bg-zinc-900 px-1.5 py-0.5 rounded border border-stealth">Score: {event.score}</div>}
									</div>
								</Card>
							</div>
						</div>
					))}
				</div>
			</div>

			<!-- Sidebar -->
			<div class="space-y-12 px-2">
				<div>
					<h2 class="text-xl font-black tracking-tighter mb-6 flex items-center gap-2">
						<Activity class="w-5 h-5 text-accent-cyan" />
						Upcoming Missions
					</h2>
					<div class="space-y-4">
						{upcomingEvents.length > 0 ? upcomingEvents.map(event => (
							<Card class="border-accent-cyan/20 bg-accent-cyan/5 p-5">
								<h3 class="font-bold text-white mb-1">{event.name}</h3>
								<p class="text-xs text-zinc-400 mb-5">{event.date}</p>
								<a href={event.link} class="inline-flex items-center text-[10px] font-bold uppercase tracking-[0.2em] text-accent-cyan hover:text-white transition-colors py-2">
									Briefing Docs
									<ExternalLink class="w-3 h-3 ml-2" />
								</a>
							</Card>
						)) : (
							<div class="p-8 rounded-xl border border-dashed border-stealth text-center bg-white/[0.01]">
								<p class="text-xs text-zinc-600 uppercase tracking-widest font-bold font-mono">No active intel</p>
							</div>
						)}
					</div>
				</div>

				<div class="p-8 md:p-6 rounded-2xl bg-accent-purple/10 border border-accent-purple/20 shadow-xl shadow-accent-purple/5">
					<h3 class="font-bold text-white text-lg mb-2">Want to compete?</h3>
					<p class="text-sm text-zinc-400 mb-6 leading-relaxed">
						We're always looking for new specialists. Check our recruitment status to see if you've got what it takes.
					</p>
					<a href="/join" class="inline-block w-full text-center px-6 py-3 rounded-full bg-accent-purple text-white text-xs font-bold uppercase tracking-widest hover:bg-purple-600 transition-all active:scale-95">
						Apply Now
					</a>
				</div>
			</div>
		</div>
	</div>
</Layout>
