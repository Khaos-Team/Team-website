---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { Shield, Target, Zap, Globe, Cpu } from 'lucide-vue-next';
---

<Layout title="About">
	<div class="max-w-7xl mx-auto px-4 py-12 md:py-20">
		<header class="mb-12 md:mb-20 px-2">
			<h1 class="text-3xl sm:text-4xl md:text-5xl font-black tracking-tighter mb-4 uppercase italic leading-tight">Operational Overview</h1>
			<p class="text-zinc-500 max-w-2xl font-mono uppercase tracking-[0.15em] text-xs leading-relaxed">Khaos is an elite Capture The Flag (CTF) team dedicated to the study of complex systems and vulnerability research.</p>
		</header>

		<div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-16 items-start mb-20 md:mb-32">
			<div class="space-y-12 px-2">
				<section>
					<h2 class="text-xl md:text-2xl font-black tracking-tighter uppercase mb-5 flex items-center gap-3">
						<div class="w-8 h-8 rounded-lg bg-accent-purple/10 flex items-center justify-center border border-accent-purple/20">
							<Target class="w-4 h-4 text-accent-purple" />
						</div>
						CTF Mission
					</h2>
					<p class="text-zinc-400 leading-relaxed text-sm md:text-base">
						Our objective is the pursuit of technical excellence through competitive Capture The Flag (CTF) events. We focus on identifying architectural flaws and developing sophisticated exploits within controlled, high-stakes environments.
					</p>
				</section>

				<section>
					<h2 class="text-xl md:text-2xl font-black tracking-tighter uppercase mb-5 flex items-center gap-3">
						<div class="w-8 h-8 rounded-lg bg-accent-cyan/10 flex items-center justify-center border border-accent-cyan/20">
							<Cpu class="w-4 h-4 text-accent-cyan" />
						</div>
						Methodology
					</h2>
					<p class="text-zinc-400 leading-relaxed text-sm md:text-base">
						We operate with a research-first mindset. Every operation is an opportunity to refine our tooling, deepen our understanding of low-level systems, and contribute to the broader security discourse through detailed technical writeups.
					</p>
				</section>

				<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4">
					<div class="p-6 md:p-8 rounded-2xl border border-stealth bg-graphite/30 group hover:border-accent-purple/30 transition-colors">
						<div class="text-xs md:text-sm font-bold text-white uppercase mb-3 tracking-wider">Vulnerability Research</div>
						<p class="text-[11px] md:text-xs text-zinc-500 leading-relaxed">Focus on binary exploitation, heap manipulation, and cryptographic primitives.</p>
					</div>
					<div class="p-6 md:p-8 rounded-2xl border border-stealth bg-graphite/30 group hover:border-accent-cyan/30 transition-colors">
						<div class="text-xs md:text-sm font-bold text-white uppercase mb-3 tracking-wider">System Analysis</div>
						<p class="text-[11px] md:text-xs text-zinc-500 leading-relaxed">Deep dives into protocol design, kernel internals, and distributed architectures.</p>
					</div>
				</div>
			</div>

			<div class="relative group lg:sticky lg:top-32 px-2 mt-8 lg:mt-0">
				<div class="absolute -inset-1 bg-gradient-to-r from-accent-purple to-accent-cyan rounded-2xl blur opacity-10 group-hover:opacity-20 transition duration-1000"></div>
				<div class="relative rounded-2xl bg-graphite border border-stealth overflow-hidden p-6 md:p-10 font-mono text-[11px] md:text-xs text-zinc-500 leading-relaxed shadow-2xl">
					<div class="flex items-center justify-between mb-6 border-b border-stealth pb-4">
						<div class="flex items-center gap-2">
							<div class="w-2.5 h-2.5 rounded-full bg-accent-purple/40 animate-pulse"></div>
							<span class="text-white font-bold tracking-tight">KHAOS_MANIFESTO.LOG</span>
						</div>
						<div class="flex gap-1.5">
							<div class="w-2.5 h-2.5 rounded-full bg-zinc-800"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-zinc-800"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
						</div>
					</div>
					<div class="space-y-4">
						<p class="flex gap-2">
							<span class="text-accent-purple opacity-50">$</span>
							<span>INITIALIZING_PROTOCOL...</span>
						</p>
						<p class="text-zinc-400 font-bold uppercase tracking-tight">We don't just participate. We dissect.</p>
						<p>The goal is not just the flag, but the understanding of why the flag exists.</p>
						<p>Code is law, but every law has an exception.</p>
						<p class="text-white font-black italic">WE ARE THE EXCEPTION.</p>
						<div class="pt-6 flex items-center justify-between border-t border-stealth">
							<span class="text-accent-purple font-black tracking-[0.3em]">[ACTIVE]</span>
							<span class="text-[9px] text-zinc-700 uppercase">Version 2.4.0</span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</Layout>
